# ================================
# Backend Environment Configuration
# ================================

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DB_CONNECT=mongodb+srv://username:password@cluster.mongodb.net/uber_clone?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# CORS Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Google Maps API (Optional - for ride tracking)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Twilio Configuration (Optional - for SMS/Calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional - for notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_SERVICE=gmail

# Payment Gateway (Optional - for payments)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Environment
APP_NAME=Uber Clone
APP_VERSION=1.0.0
